<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.paint.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="700.0" prefWidth="900.0" style="-fx-background-color: #F2F2F2;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sistematutoriascomp.sistematutorias.controller.reporte.FXMLConsultarReporteTutoriaController">
   <children>
      <BorderPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         
         <top>
            <HBox alignment="CENTER_LEFT" prefHeight="80.0" spacing="12.0" style="-fx-background-color: #18529d; -fx-padding: 0 20 0 20;">
               <children>
                  <Label text="Sistema de Tutorías" textFill="WHITE">
                     <font>
                        <Font name="Segoe UI Bold" size="22.0" />
                     </font>
                  </Label>
                  <Region HBox.hgrow="ALWAYS" />
                  <Button mnemonicParsing="false" onAction="#clicCerrarSesion" style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand; -fx-font-size: 18;" text="Cerrar sesión">
                     <font>
                        <Font name="Segoe UI Semibold" size="14.0" />
                     </font>
                  </Button>
               </children>
            </HBox>
         </top>

         <center>
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #F2F2F2;">
               <content>
                  <VBox alignment="TOP_CENTER" spacing="20.0" style="-fx-padding: 30;">
                     <children>
                        <Label text="Detalles del Reporte de Tutoría" textFill="#18529d">
                           <font>
                              <Font name="Segoe UI Bold" size="20.0" />
                           </font>
                        </Label>
                        <VBox maxWidth="800.0" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 30;">
                           <effect>
                              <DropShadow offsetY="2.0" radius="10.0">
                                 <color>
                                    <Color opacity="0.15" />
                                 </color>
                              </DropShadow>
                           </effect>
                           <children>
                              <HBox alignment="CENTER_LEFT" spacing="20.0">
                                 <children>
                                    <Label text="Estatus:" textFill="#333333">
                                       <font><Font name="Segoe UI Bold" size="16.0" /></font>
                                    </Label>
                                    <Label fx:id="lbEstatus" style="-fx-background-color: #FFF3CD; -fx-text-fill: #856404; -fx-padding: 5 10; -fx-background-radius: 5; -fx-border-color: #FFEEBA; -fx-border-radius: 5;" text="BORRADOR">
                                       <font><Font name="Segoe UI Bold" size="14.0" /></font>
                                    </Label>
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label text="Fecha de Creación:" textFill="#666666">
                                       <font><Font name="Segoe UI" size="14.0" /></font>
                                    </Label>
                                    <Label fx:id="lbFecha" text="DD/MM/AAAA" textFill="#333333">
                                       <font><Font name="Segoe UI Bold" size="14.0" /></font>
                                    </Label>
                                 </children>
                              </HBox>
                              
                              <Separator prefWidth="200.0" />
                              
                              <GridPane hgap="30.0" vgap="10.0">
                                 <columnConstraints>
                                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" />
                                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" />
                                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" />
                                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" />
                                 </columnConstraints>
                                 <rowConstraints>
                                    <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                                    <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                                 </rowConstraints>
                                 <children>
                                    <Label text="Total Tutorados" textFill="#555555">
                                       <font><Font name="Segoe UI" size="12.0" /></font>
                                    </Label>
                                    <Label fx:id="lbTotalTutorados" text="0" textFill="#18529d" GridPane.rowIndex="1">
                                       <font><Font name="Segoe UI Bold" size="24.0" /></font>
                                    </Label>

                                    <Label text="Asistentes" textFill="#555555" GridPane.columnIndex="1">
                                       <font><Font name="Segoe UI" size="12.0" /></font>
                                    </Label>
                                    <Label fx:id="lbTotalAsistentes" text="0" textFill="#2e7d32" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                       <font><Font name="Segoe UI Bold" size="24.0" /></font>
                                    </Label>

                                    <Label text="Inasistentes" textFill="#555555" GridPane.columnIndex="2">
                                       <font><Font name="Segoe UI" size="12.0" /></font>
                                    </Label>
                                    <Label fx:id="lbTotalInasistentes" text="0" textFill="#c62828" GridPane.columnIndex="2" GridPane.rowIndex="1">
                                       <font><Font name="Segoe UI Bold" size="24.0" /></font>
                                    </Label>

                                    <Label text="Problemáticas" textFill="#555555" GridPane.columnIndex="3">
                                       <font><Font name="Segoe UI" size="12.0" /></font>
                                    </Label>
                                    <Label fx:id="lbTotalProblematicas" text="0" textFill="#6a1b9a" GridPane.columnIndex="3" GridPane.rowIndex="1">
                                       <font><Font name="Segoe UI Bold" size="24.0" /></font>
                                    </Label>
                                 </children>
                              </GridPane>
                              
                              <Separator prefWidth="200.0" />
                              
                              <VBox spacing="10.0">
                                 <children>
                                    <HBox alignment="CENTER_LEFT" spacing="15.0">
                                       <children>
                                          <Label text="Problemáticas Detectadas:" textFill="#333333">
                                             <font><Font name="Segoe UI Bold" size="16.0" /></font>
                                          </Label>
                                          <Region HBox.hgrow="ALWAYS" />
                                          <Button fx:id="btnDescargarEvidencia" mnemonicParsing="false" onAction="#clicVerEvidencia" style="-fx-background-color: #6f42c1; -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 5;" text="Ver evidencia">
                                             <font><Font name="Segoe UI Bold" size="13.0" /></font>
                                          </Button>
                                       </children>
                                    </HBox>
                                    
                                    <TableView fx:id="tblProblematicas" 
           prefHeight="200.0" 
           style="-fx-font-size: 13px;">
   <columns>
      <TableColumn fx:id="tcTitulo" prefWidth="200.0" text="Tipo / Título" />
      <TableColumn fx:id="tcDescripcion" prefWidth="550.0" text="Descripción Detallada" />
   </columns>
   <columnResizePolicy>
      <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
   </columnResizePolicy>
</TableView>
                                 </children>
                              </VBox>

                              <Separator prefWidth="200.0" />
                              
                              <VBox spacing="8.0">
                                 <children>
                                    <Label text="Observaciones Generales:" textFill="#333333">
                                       <font><Font name="Segoe UI Bold" size="16.0" /></font>
                                    </Label>
                                    <TextArea fx:id="txtaObservaciones" editable="false" prefHeight="80.0" style="-fx-font-size: 15; -fx-background-color: #f9f9f9;" wrapText="true" />
                                 </children>
                              </VBox>
                              
                              <VBox fx:id="vbRespuesta" managed="false" spacing="8.0" visible="false">
                                 <children>
                                    <Separator prefWidth="200.0" />
                                    <Label text="Retroalimentación del Coordinador:" textFill="#18529d">
                                       <font><Font name="Segoe UI Bold" size="16.0" /></font>
                                    </Label>
                                    <TextArea fx:id="txtaRespuesta" editable="false" prefHeight="80.0" style="-fx-font-size: 15; -fx-background-color: #E8F0FE; -fx-control-inner-background: #E8F0FE;" wrapText="true" />
                                 </children>
                              </VBox>
                              
                              <Separator prefWidth="200.0" />
                              
                              <HBox alignment="CENTER_RIGHT" spacing="15.0">
                                 <children>
                                    <Button mnemonicParsing="false" onAction="#clicVolver" prefHeight="40.0" prefWidth="100.0" style="-fx-background-color: #969696; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand; -fx-font-size: 18;" text="Volver">
                                       <font><Font name="Segoe UI Bold" size="14.0" /></font>
                                    </Button>
                                    
                                    <Button fx:id="btnEnviar" managed="false" mnemonicParsing="false" onAction="#clicEnviar" prefHeight="40.0" prefWidth="100.0" style="-fx-background-color: #41B71A; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand; -fx-font-size: 18;" text="Enviar" visible="false">
                                       <font><Font name="Segoe UI Bold" size="14.0" /></font>
                                    </Button>
                                    
                                    <Button fx:id="btnResponder" managed="false" mnemonicParsing="false" onAction="#clicResponder" prefHeight="40.0" prefWidth="130.0" style="-fx-background-color: #18529d; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand; -fx-font-size: 18;" text="Responder" visible="false">
                                       <font><Font name="Segoe UI Bold" size="14.0" /></font>
                                    </Button>
                                 </children>
                              </HBox>
                              
                           </children>
                        </VBox>
                     </children>
                  </VBox>
               </content>
            </ScrollPane>
         </center>
      </BorderPane>
   </children>
</AnchorPane>
