<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.paint.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #F2F2F2;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sistematutoriascomp.sistematutorias.controller.reporte.FXMLListadoReportesTutoriaController">
   <children>
      <BorderPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <top>
            <HBox alignment="CENTER_LEFT" prefHeight="80.0" spacing="12.0" style="-fx-background-color: #18529d; -fx-padding: 0 20 0 20;">
               <children>
                  <Label text="Sistema de Tutorías" textFill="WHITE">
                     <font>
                        <Font name="Segoe UI Bold" size="22.0" />
                     </font>
                  </Label>
                  <Region HBox.hgrow="ALWAYS" />
                  <Button mnemonicParsing="false" onAction="#clicCerrarSesion" style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand; -fx-font-size: 18;" text="Cerrar sesión">
                     <font>
                        <Font name="Segoe UI Semibold" size="14.0" />
                     </font>
                  </Button>
               </children>
            </HBox>
         </top>
         <center>
            <VBox spacing="20.0" style="-fx-padding: 30;">
               <children>
                  <Label text="Mis Reportes de Tutoría" textFill="#18529d">
                     <font>
                        <Font name="Segoe UI Bold" size="20.0" />
                     </font>
                  </Label>
                  
                  <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10;">
                     <effect>
                        <DropShadow color="#0000001a" offsetY="2.0" radius="5.0" />
                     </effect>
                     <children>
                        <Label text="Periodo Escolar:">
                           <font>
                              <Font name="Segoe UI Bold" size="14.0" />
                           </font>
                        </Label>
                        <ComboBox fx:id="cbPeriodos" prefWidth="250.0" promptText="-- Seleccionar Periodo --" style="-fx-font-size: 14;" />
                        <Button mnemonicParsing="false" onAction="#clicBuscar" style="-fx-background-color: #18529d; -fx-text-fill: white; -fx-cursor: hand;" text="Buscar">
                           <font>
                              <Font name="Segoe UI Bold" size="14.0" />
                           </font>
                        </Button>
                     </children>
                  </HBox>
                  <TableView fx:id="tblReportesTutoria" style="-fx-font-size: 15;" VBox.vgrow="ALWAYS">
                    <columns>
                      <TableColumn fx:id="tcFechaGeneracion" prefWidth="180.0" text="Fecha Generación" />
                      <TableColumn fx:id="tcEstatus" prefWidth="120.0" style="-fx-alignment: CENTER;" text="Estatus" />
                      <TableColumn fx:id="tcObservaciones" prefWidth="400.0" text="Observaciones (Vista Previa)" />
                    </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
                  <HBox alignment="CENTER_RIGHT" spacing="15.0">
                     <children>
                        <Button mnemonicParsing="false" onAction="#clicVolver" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #969696; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand; -fx-font-size: 18;" text="Volver">
                           <font>
                              <Font name="Segoe UI Bold" size="14.0" />
                           </font>
                        </Button>
                        <Button mnemonicParsing="false" onAction="#clicConsultar" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: #18529d; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand; -fx-font-size: 18;" text="Consultar">
                           <font>
                              <Font name="Segoe UI Bold" size="14.0" />
                           </font>
                        </Button>
                     </children>
                  </HBox>
               </children>
            </VBox>
         </center>
      </BorderPane>
   </children>
</AnchorPane>