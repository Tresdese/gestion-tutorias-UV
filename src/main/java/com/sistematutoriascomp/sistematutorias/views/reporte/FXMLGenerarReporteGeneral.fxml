<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.paint.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #F2F2F2;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sistematutoriascomp.sistematutorias.controller.reporte.FXMLGenerarReporteGeneralController">
   <children>
      <BorderPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <top>
            <HBox alignment="CENTER_LEFT" prefHeight="80.0" spacing="12.0" style="-fx-background-color: #18529d; -fx-padding: 0 20 0 20;">
               <children>
                  <Label text="Sistema de Tutorías" textFill="WHITE">
                     <font>
                        <Font name="Segoe UI Bold" size="22.0" />
                     </font>
                  </Label>
                  <Region HBox.hgrow="ALWAYS" />
                  <Button mnemonicParsing="false" onAction="#clicCerrarSesion" style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand; -fx-font-size: 18;" text="Cerrar sesión">
                     <font>
                        <Font name="Segoe UI Semibold" size="14.0" />
                     </font>
                  </Button>
               </children>
            </HBox>
         </top>

         <center>
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #F2F2F2;">
               <content>
                  <VBox alignment="TOP_CENTER" spacing="20.0" style="-fx-padding: 30;">
                     <children>
                        
                        <Label text="Generar Nuevo Reporte General" textFill="#18529d">
                           <font>
                              <Font name="Segoe UI Bold" size="20.0" />
                           </font>
                        </Label>

                        <VBox maxWidth="850.0" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20;">
                           <effect>
                              <DropShadow offsetY="2.0" radius="10.0">
                                 <color>
                                    <Color opacity="0.15" />
                                 </color>
                              </DropShadow>
                           </effect>
                           <children>
                              <HBox alignment="CENTER_LEFT" spacing="20.0">
                                 <children>
                                    <VBox spacing="5.0">
                                       <children>
                                          <Label text="Periodo Escolar:">
                                             <font>
                                                <Font name="Segoe UI Bold" size="14.0" />
                                             </font>
                                          </Label>
                                          <ComboBox fx:id="cbPeriodo" prefWidth="250.0" promptText="-- Seleccionar --" style="-fx-font-size: 14;" />
                                       </children>
                                    </VBox>
                                    
                                    <VBox spacing="5.0">
                                       <children>
                                          <Label text="Número de Sesión:">
                                             <font>
                                                <Font name="Segoe UI Bold" size="14.0" />
                                             </font>
                                          </Label>
                                          <ComboBox fx:id="cbNumeroSesion" prefWidth="180.0" promptText="-- Seleccionar --" style="-fx-font-size: 14;" />
                                       </children>
                                    </VBox>
                                    
                                    <Region HBox.hgrow="ALWAYS" />
                                    
                                    <Button fx:id="btnVolver" mnemonicParsing="false" onAction="#clicVolver" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #969696; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;" text="Volver">
                                       <font>
                                          <Font name="Segoe UI Bold" size="14.0" />
                                       </font>
                                       <HBox.margin>
                                          <Insets top="22.0" />
                                       </HBox.margin>
                                    </Button>

                                    <Button fx:id="btnGenerar" mnemonicParsing="false" onAction="#clicGenerar" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #18529d; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;" text="Generar">
                                       <font>
                                          <Font name="Segoe UI Bold" size="14.0" />
                                       </font>
                                       <HBox.margin>
                                          <Insets top="22.0" />
                                       </HBox.margin>
                                    </Button>
                                 </children>
                              </HBox>
                           </children>
                        </VBox>

                        <VBox fx:id="vbDatosReporte" managed="false" maxWidth="850.0" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 30;" visible="false">
                           <effect>
                              <DropShadow offsetY="2.0" radius="10.0">
                                 <color>
                                    <Color opacity="0.15" />
                                 </color>
                              </DropShadow>
                           </effect>
                           <children>
                              <Label text="Estadísticas de la Sesión" textFill="#666666">
                                 <font>
                                    <Font name="Segoe UI Bold" size="16.0" />
                                 </font>
                              </Label>
                              <Separator prefWidth="200.0" />
                              
                              <GridPane hgap="30.0" vgap="15.0">
                                 <columnConstraints>
                                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" />
                                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" />
                                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" />
                                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" />
                                 </columnConstraints>
                                 <rowConstraints>
                                    <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                                    <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                                 </rowConstraints>
                                 <children>
                                    <Label text="Total Tutorados" textFill="#555555">
                                       <font><Font name="Segoe UI" size="12.0" /></font>
                                    </Label>
                                    <Label fx:id="lbTotalTutorados" text="0" textFill="#18529d" GridPane.rowIndex="1">
                                       <font><Font name="Segoe UI Bold" size="24.0" /></font>
                                    </Label>

                                    <Label text="Asistentes" textFill="#555555" GridPane.columnIndex="1">
                                       <font><Font name="Segoe UI" size="12.0" /></font>
                                    </Label>
                                    <Label fx:id="lbTotalAsistentes" text="0" textFill="#2e7d32" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                       <font><Font name="Segoe UI Bold" size="24.0" /></font>
                                    </Label>

                                    <Label text="Inasistentes" textFill="#555555" GridPane.columnIndex="2">
                                       <font><Font name="Segoe UI" size="12.0" /></font>
                                    </Label>
                                    <Label fx:id="lbTotalInasistentes" text="0" textFill="#c62828" GridPane.columnIndex="2" GridPane.rowIndex="1">
                                       <font><Font name="Segoe UI Bold" size="24.0" /></font>
                                    </Label>

                                    <Label text="Total Problemáticas" textFill="#555555" GridPane.columnIndex="3">
                                       <font><Font name="Segoe UI" size="12.0" /></font>
                                    </Label>
                                    <Label fx:id="lbTotalProblematicas" text="0" textFill="#6a1b9a" GridPane.columnIndex="3" GridPane.rowIndex="1">
                                       <font><Font name="Segoe UI Bold" size="24.0" /></font>
                                    </Label>
                                 </children>
                              </GridPane>
                              
                              <Separator prefWidth="200.0" />
                              
                              <VBox spacing="8.0">
                                 <children>
                                     <Label text="Detalle de Problemáticas Reportadas:" textFill="#333333">
                                       <font>
                                          <Font name="Segoe UI Bold" size="16.0" />
                                       </font>
                                    </Label>
                                    <TableView fx:id="tblProblematicas" prefHeight="150.0" style="-fx-font-size: 14;">
                                      <columns>
                                        <TableColumn fx:id="tcTitulo" prefWidth="200.0" text="Tipo / Título" />
                                        <TableColumn fx:id="tcDescripcion" prefWidth="550.0" text="Descripción" />
                                      </columns>
                                       <columnResizePolicy>
                                          <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                       </columnResizePolicy>
                                    </TableView>
                                 </children>
                              </VBox>
                              
                              <Separator prefWidth="200.0" />
                              
                              <VBox spacing="8.0">
                                 <children>
                                    <Label text="Comentarios Generales:" textFill="#333333">
                                       <font>
                                          <Font name="Segoe UI Bold" size="16.0" />
                                       </font>
                                    </Label>
                                    <TextArea fx:id="txtaComentariosGenerales" prefHeight="120.0" promptText="Escriba aquí los comentarios generales de la sesión..." style="-fx-font-size: 14;" wrapText="true" />
                                 </children>
                              </VBox>
                              
                              <Separator prefWidth="200.0" />
                              
                              <HBox alignment="CENTER_RIGHT" spacing="15.0">
                                 <children>
                                    <HBox fx:id="hbBotonesEdicion" spacing="15.0">
                                       <children>
                                          <Button mnemonicParsing="false" onAction="#clicCancelar" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #969696; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand; -fx-font-size: 18;" text="Cancelar">
                                             <font>
                                                <Font name="Segoe UI Bold" size="14.0" />
                                             </font>
                                          </Button>
                                          <Button mnemonicParsing="false" onAction="#clicGuardar" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #41B71A; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand; -fx-font-size: 18;" text="Guardar">
                                             <font>
                                                <Font name="Segoe UI Bold" size="14.0" />
                                             </font>
                                          </Button>
                                       </children>
                                    </HBox>
                                    
                                    <Button fx:id="btnFinalizar" managed="false" mnemonicParsing="false" onAction="#clicVolver" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #18529d; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand; -fx-font-size: 18;" text="Volver" visible="false">
                                       <font>
                                          <Font name="Segoe UI Bold" size="14.0" />
                                       </font>
                                    </Button>
                                 </children>
                              </HBox>

                           </children>
                        </VBox>
                     </children>
                  </VBox>
               </content>
            </ScrollPane>
         </center>
      </BorderPane>
   </children>
</AnchorPane>
