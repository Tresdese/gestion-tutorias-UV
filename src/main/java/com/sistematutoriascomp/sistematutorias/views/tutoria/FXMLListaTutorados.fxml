<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.paint.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: linear-gradient(to bottom right, #F2F2F2, #E6E6E6);" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sistematutoriascomp.sistematutorias.controller.tutoria.FXMLListaTutoradosController">
   <children>
      <BorderPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <top>
            <HBox alignment="CENTER_LEFT" prefHeight="80.0" spacing="12.0" style="-fx-background-color: #18529d; -fx-padding: 0 20 0 20;">
               <children>
                  <Label text="Sistema de Tutorías" textFill="WHITE">
                     <font>
                        <Font name="Segoe UI Bold" size="22.0" />
                     </font>
                  </Label>
                  <Region HBox.hgrow="ALWAYS" />
                  <Button mnemonicParsing="false" onAction="#clicCerrarSesion" style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand;" text="Cerrar sesión">
                     <font>
                        <Font name="Segoe UI Semibold" size="14.0" />
                     </font>
                  </Button>
               </children>
            </HBox>
         </top>
         <center>
            <VBox alignment="TOP_CENTER" spacing="20.0" style="-fx-padding: 20;">
               <children>
                  <VBox maxWidth="860.0" prefHeight="480.0" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 25;">
                     <effect>
                        <DropShadow offsetY="2.0" radius="10.0">
                           <color>
                              <Color opacity="0.15" />
                           </color>
                        </DropShadow>
                     </effect>
                     <children>
                        <VBox>
                           <children>
                              <Label text="Gestión de Tutorados" textFill="#18529d">
                                 <font>
                                    <Font name="Segoe UI Bold" size="19.0" />
                                 </font>
                              </Label>
                              <Label text="Seleccione un tutorado para editarlo o darlo de baja." textFill="#666666">
                                 <font>
                                    <Font name="Segoe UI" size="15.0" />
                                 </font>
                              </Label>
                           </children>
                        </VBox>
                        <Separator prefWidth="200.0" />
                        <TableView fx:id="tblTutorados" style="-fx-font-size: 13;" VBox.vgrow="ALWAYS">
                           <columns>
                              <TableColumn fx:id="tcMatricula" prefWidth="100.0" text="Matrícula" />
                              <TableColumn fx:id="tcNombre" prefWidth="130.0" text="Nombre(s)" />
                              <TableColumn fx:id="tcApellidoPaterno" prefWidth="130.0" text="Apellido Paterno" />
                              <TableColumn fx:id="tcApellidoMaterno" prefWidth="130.0" text="Apellido Materno" />
                              <TableColumn fx:id="tcSemestre" prefWidth="80.0" style="-fx-alignment: CENTER;" text="Semestre" />
                              <TableColumn fx:id="tcEstado" prefWidth="90.0" style="-fx-alignment: CENTER;" text="Estado" />
                           </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                        <Separator prefHeight="0.0" prefWidth="810.0" />
                        <HBox alignment="CENTER_RIGHT" spacing="15.0">
                           <children>
                              <Button fx:id="btnDarBaja" mnemonicParsing="false" onAction="#clicDarBaja" prefHeight="40.0" prefWidth="140.0" style="-fx-background-color: #D32F2F; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;" text="Dar de Baja">
                                 <font><Font name="Segoe UI Bold" size="14.0" /></font>
                              </Button>
                              <Button fx:id="btnEditar" mnemonicParsing="false" onAction="#clicEditar" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #18529d; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;" text="Editar">
                                 <font><Font name="Segoe UI Bold" size="14.0" /></font>
                              </Button>
                           </children>
                        </HBox>
                     </children>
                  </VBox>
                  <Button mnemonicParsing="false" onAction="#clicVolver" style="-fx-background-color: transparent; -fx-text-fill: #666666; -fx-cursor: hand;" text="⬅ Volver al Menú de Gestión">
                     <font>
                        <Font name="Segoe UI" size="16.0" />
                     </font>
                  </Button>
               </children>
            </VBox>
         </center>
      </BorderPane>
   </children>
</AnchorPane>
