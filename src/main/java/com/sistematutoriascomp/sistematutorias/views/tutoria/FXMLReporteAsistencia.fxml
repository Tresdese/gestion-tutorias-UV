<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.paint.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: linear-gradient(to bottom right, #F2F2F2, #E6E6E6);" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sistematutoriascomp.sistematutorias.controller.tutoria.FXMLReporteAsistenciaController">
    <children>
        <BorderPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

            <top>
                <HBox alignment="CENTER_LEFT" prefHeight="80.0" spacing="12.0" style="-fx-background-color: #18529d; -fx-padding: 0 20 0 20;">
                    <children>
                        <Region HBox.hgrow="ALWAYS" />
                        <Label text="Reporte de Asistencia" textFill="WHITE">
                            <font>
                                <Font name="Segoe UI Bold" size="22.0" />
                            </font>
                        </Label>
                    </children>
                </HBox>
            </top>

            <center>
                <VBox alignment="TOP_CENTER" spacing="18.0" style="-fx-padding: 24;">
                    <children>

                        <Label maxWidth="850.0" text="Historial de asistencias de sus tutorados en el periodo actual." textFill="#666666" wrapText="true">
                            <font>
                                <Font name="Segoe UI" size="14.0" />
                            </font>
                        </Label>

                        <VBox maxWidth="860.0" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 20;" VBox.vgrow="ALWAYS">
                            <effect>
                                <DropShadow offsetY="2.0" radius="16.0">
                                    <color>
                                        <Color opacity="0.18" />
                                    </color>
                                </DropShadow>
                            </effect>
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="30.0">
                                    <children>
                                        <VBox alignment="CENTER" spacing="2.0" style="-fx-background-color: #e8f0fe; -fx-background-radius: 8; -fx-padding: 10 20;">
                                            <children>
                                                <Label fx:id="lbTotalRegistros" text="0" textFill="#18529d">
                                                    <font><Font name="Segoe UI Bold" size="26.0" /></font>
                                                </Label>
                                                <Label text="Total registros" textFill="#555555">
                                                    <font><Font name="Segoe UI" size="12.0" /></font>
                                                </Label>
                                            </children>
                                        </VBox>
                                        <VBox alignment="CENTER" spacing="2.0" style="-fx-background-color: #e8f5e9; -fx-background-radius: 8; -fx-padding: 10 20;">
                                            <children>
                                                <Label fx:id="lbTotalAsistencias" text="0" textFill="#2e7d32">
                                                    <font><Font name="Segoe UI Bold" size="26.0" /></font>
                                                </Label>
                                                <Label text="Asistencias" textFill="#555555">
                                                    <font><Font name="Segoe UI" size="12.0" /></font>
                                                </Label>
                                            </children>
                                        </VBox>
                                        <VBox alignment="CENTER" spacing="2.0" style="-fx-background-color: #fce4ec; -fx-background-radius: 8; -fx-padding: 10 20;">
                                            <children>
                                                <Label fx:id="lbTotalFaltas" text="0" textFill="#c62828">
                                                    <font><Font name="Segoe UI Bold" size="26.0" /></font>
                                                </Label>
                                                <Label text="Faltas" textFill="#555555">
                                                    <font><Font name="Segoe UI" size="12.0" /></font>
                                                </Label>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <Separator />

                                <TableView fx:id="tblReporte" prefHeight="360.0" style="-fx-font-size: 13px;" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="tcMatricula" prefWidth="110.0" text="Matrícula" />
                                        <TableColumn fx:id="tcNombre" prefWidth="250.0" text="Nombre" />
                                        <TableColumn fx:id="tcSemestre" prefWidth="80.0" style="-fx-alignment: CENTER;" text="Semestre" />
                                        <TableColumn fx:id="tcFechaSesion" prefWidth="120.0" style="-fx-alignment: CENTER;" text="Fecha Sesión" />
                                        <TableColumn fx:id="tcAsistencia" prefWidth="110.0" style="-fx-alignment: CENTER;" text="Asistencia" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                    <placeholder>
                                        <Label text="No hay asistencias para mostrar." />
                                    </placeholder>
                                </TableView>
                            </children>
                        </VBox>

                        <HBox alignment="CENTER_RIGHT" spacing="15.0">
                            <children>
                                <Button mnemonicParsing="false" onAction="#clicCerrar" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #969696; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;" text="Cerrar">
                                    <font>
                                        <Font name="Segoe UI Bold" size="14.0" />
                                    </font>
                                </Button>
                            </children>
                        </HBox>

                    </children>
                </VBox>
            </center>
        </BorderPane>
    </children>
</AnchorPane>
